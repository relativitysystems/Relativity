PORT=3000

# Supabase — fill these in when you create your Supabase project
SUPABASE_URL=https://placeholder.supabase.co
SUPABASE_SERVICE_KEY=placeholder-service-key

# Dropbox App — from https://www.dropbox.com/developers/apps
DROPBOX_APP_KEY=placeholder-app-key
DROPBOX_APP_SECRET=placeholder-app-secret
DROPBOX_REDIRECT_URI=http://localhost:3000/auth/dropbox/callback

# Shared secret for n8n — generate any long random string
N8N_API_KEY=placeholder-n8n-api-key
