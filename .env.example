PORT=3000
APP_BASE_URL=

# Backlog M6 — explicit CORS policy (middleware/corsPolicy.js). Optional,
# comma-separated list of ADDITIONAL browser origins allowed to call this
# API cross-origin (e.g. a staging domain). APP_BASE_URL above is always
# allowed and does not need to be repeated here. Leave unset for a normal
# single-domain deployment.
ALLOWED_ORIGINS=

# Admin dashboard credentials
ADMIN_PASSWORD=
ADMIN_JWT_SECRET=

OPENAI_API_KEY=

GLOBAL_SUPABASE_URL=
GLOBAL_SUPABASE_SERVICE_ROLE_KEY=
# Anon key — safe to expose to browser via /auth/config
GLOBAL_SUPABASE_ANON_KEY=

AIKB_SUPABASE_URL=
AIKB_SUPABASE_SERVICE_ROLE_KEY=

AIKB_API_BASE_URL=
AIKB_API_KEY=
AIKB_STORAGE_BUCKET=

AI_BDR_API_URL=
AI_BDR_INTERNAL_API_KEY=

# Slack OAuth v2 — from https://api.slack.com/apps (OAuth & Permissions page
# for Client ID/Secret, Basic Information page for Signing Secret). Bot
# scopes requested by the app: app_mentions:read, chat:write only — no
# incoming-webhook, no direct-message or channel-history scopes.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# Verifies incoming Slack Events API requests. Not used by the OAuth
# connect/callback flow itself — reserved for a future milestone that adds
# the Slack Events endpoint.
SLACK_SIGNING_SECRET=
# Must exactly match the Redirect URL configured in the Slack app's OAuth &
# Permissions page. Production: https://relativitysystems.ai/api/integrations/slack/callback
SLACK_REDIRECT_URI=

# Encrypts OAuth integration credentials at rest (oauth_credentials table).
# Provider-neutral — used for Slack today, and by any future provider
# (Microsoft, Gmail) that migrates onto oauth_connections/oauth_credentials.
# Google Drive and Dropbox previously used this too, until backlog M15
# removed their persistent-connection flow entirely. See
# services/integrationCredentialEncryption.js.
# - 64 hexadecimal characters, generated from 32 random bytes
#   (e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`)
# - never commit the real value
# - this is always the key for the CURRENT version (see
#   INTEGRATION_CREDENTIAL_ENCRYPTION_KEY_VERSION below) — key rotation
#   (backlog M3) is supported; see services/integrationCredentialEncryption.js
INTEGRATION_CREDENTIAL_ENCRYPTION_KEY=
# DEPRECATED — temporary fallback only, read if
# INTEGRATION_CREDENTIAL_ENCRYPTION_KEY is unset. Do not set both; set only
# the variable above. This name will stop being read in a future migration.
# SLACK_TOKEN_ENCRYPTION_KEY=

# Backlog M3 — which key version INTEGRATION_CREDENTIAL_ENCRYPTION_KEY
# currently represents. Optional — defaults to 1 if unset, so no existing
# environment needs to set this until its first rotation. To rotate: bump
# this to a new integer, put a freshly generated key in
# INTEGRATION_CREDENTIAL_ENCRYPTION_KEY, and set
# INTEGRATION_CREDENTIAL_ENCRYPTION_KEY_V{oldVersion} (e.g.
# INTEGRATION_CREDENTIAL_ENCRYPTION_KEY_V1) to the OLD key so rows not yet
# re-encrypted still decrypt. Run scripts/rotateCredentialEncryptionKey.js
# to re-encrypt every row under the new key, then remove the old
# INTEGRATION_CREDENTIAL_ENCRYPTION_KEY_V{oldVersion} variable.
# INTEGRATION_CREDENTIAL_ENCRYPTION_KEY_VERSION=1

# Architecture Review Phase 4, Milestone 4 — additive HMAC service-request
# envelope shared between Relativity and AIKB, scoped ONLY to
# POST /api/knowledge/ask and POST /api/integrations/slack/deliver. Distinct
# from AIKB_API_KEY below (unchanged, still gates every other AIKB route).
# Must be identical in both repos' environments.
# - 64 hexadecimal characters, generated the same way as
#   INTEGRATION_CREDENTIAL_ENCRYPTION_KEY above.
SERVICE_REQUEST_SIGNING_SECRET=

# Optional — caps the extracted Slack question length forwarded to AIKB.
# Defaults to 2000 if unset.
SLACK_QUESTION_MAX_LENGTH=

# Optional — timeout (ms) for the fast accept-and-enqueue call to AIKB's
# POST /api/knowledge/ask, made synchronously before acking Slack. Defaults
# to 4000 if unset.
AIKB_ASK_TIMEOUT_MS=

# Optional — timeout (ms) for the best-effort callback to AIKB's
# POST /api/knowledge/chat/redact once a Slack event reaches the terminal
# delivery_failed state (ADR-007). Defaults to 4000 if unset.
AIKB_REDACT_TIMEOUT_MS=

# Optional — ADR-007 bounded Slack delivery retries. SLACK_DELIVERY_MAX_ATTEMPTS
# is the total number of attempts (initial + retries) before a Slack event is
# marked delivery_failed; defaults to 3. SLACK_DELIVERY_BACKOFF_MS is a
# comma-separated list of wait times (ms) between attempts; defaults to
# "2000,5000" (attempt 1 -> wait 2s -> attempt 2 -> wait 5s -> attempt 3).
# There is no scheduled sweep or cron job for Slack delivery — every retry
# happens synchronously within the request/flow that triggered it. The
# formerly-required CRON_SECRET (for the now-removed
# GET /api/integrations/slack/sweep endpoint) no longer applies to anything;
# see decisions/ADR-007-SLACK-BOUNDED-DELIVERY-RETRY.md in the Architecture repo.
SLACK_DELIVERY_MAX_ATTEMPTS=
SLACK_DELIVERY_BACKOFF_MS=

# Google Drive Picker — from https://console.cloud.google.com/apis/credentials.
# Browser-side one-shot copy import only (routes/api.js); backlog M15 removed
# the separate persistent-connection OAuth flow, so GOOGLE_CLIENT_SECRET/
# GOOGLE_REDIRECT_URI are no longer needed.
GOOGLE_CLIENT_ID=
GOOGLE_PICKER_API_KEY=

# Gmail OAuth per member (EM2 — Architecture/architecture/EMAIL_INGESTION.md).
# A separate, real server-side OAuth 2.0 Client (Web application type) from
# the Google Drive Picker above — this one needs a client secret since it
# performs an authorization-code token exchange, not a browser-only picker
# flow. Scopes requested: gmail.readonly + gmail.labels + openid email
# profile — gmail.labels was added in EM5 to create the managed
# "Relativity/Knowledge" label. Reuses the existing
# INTEGRATION_CREDENTIAL_ENCRYPTION_KEY.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# Must exactly match a Redirect URI configured on the OAuth Client.
# Production: https://relativitysystems.ai/api/integrations/email/gmail/callback
GMAIL_REDIRECT_URI=

TEST_BASE_URL=
TEST_CLIENT_EMAIL=
TEST_CLIENT_PASSWORD=
TEST_DOCUMENT_FILE=