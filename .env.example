PORT=3000

# Supabase — service role key is server-side only, never expose to browser
GLOBAL_SUPABASE_URL=https://your-project.supabase.co
GLOBAL_SUPABASE_SERVICE_KEY=your-service-role-key
# Anon key is safe for browser — returned by GET /auth/config
GLOBAL_SUPABASE_ANON_KEY=your-anon-key

# Dropbox App — from https://www.dropbox.com/developers/apps
DROPBOX_APP_KEY=your-dropbox-app-key
DROPBOX_APP_SECRET=your-dropbox-app-secret
# Must exactly match what you set in the Dropbox App Console
DROPBOX_REDIRECT_URI=http://localhost:3000/auth/dropbox/callback
# Root path to watch inside client Dropbox (leave empty for root)
DROPBOX_BASE_PATH=

# Inngest — from https://app.inngest.com
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# Slack OAuth — from your Slack app (api.slack.com/apps)
SLACK_APP_ID=your-slack-app-id
SLACK_APP_SECRET=your-slack-app-secret
# Must exactly match what you set in the Slack App OAuth Redirect URLs
SLACK_REDIRECT_URI=http://localhost:3000/auth/slack/callback

# Google Drive OAuth — from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# Must exactly match an authorized redirect URI set in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Internal API key — used by n8n/Inngest to call /api/* and /auth/status/:clientId
API_KEY=your-internal-api-key

# Lead notification emails
# Option A: Resend — https://resend.com (recommended)
RESEND_API_KEY=
EMAIL_FROM=Relativity Systems <notifications@relativitysystems.ai>
# Option B: SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Recipient for new lead notifications
LEAD_NOTIFICATION_EMAIL=tenzin@relativitysystems.ai

# AIKB (AI Knowledge Base) backend
AIKB_API_BASE_URL=http://localhost:3001
AIKB_API_KEY=your-aikb-api-key
AIKB_SUPABASE_URL=https://your-aikb-project.supabase.co
AIKB_SUPABASE_SERVICE_ROLE_KEY=your-aikb-service-role-key
AIKB_STORAGE_BUCKET=aikb-documents

# OpenAI — used for voice-to-text transcription in the Knowledge Base chat
OPENAI_API_KEY=your-openai-api-key
# Max audio upload size for voice transcription (MB)
MAX_AUDIO_SIZE_MB=10
