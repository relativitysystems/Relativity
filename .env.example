PORT=3000

# Supabase — use service role key (not anon), required for server-side writes
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Dropbox App — from https://www.dropbox.com/developers/apps
DROPBOX_APP_KEY=your-dropbox-app-key
DROPBOX_APP_SECRET=your-dropbox-app-secret
# Must exactly match what you set in the Dropbox App Console
DROPBOX_REDIRECT_URI=http://localhost:3000/auth/dropbox/callback

# Shared secret between your server and n8n — generate a long random string
N8N_API_KEY=generate-a-long-random-secret-here
