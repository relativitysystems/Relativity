PORT=3000

# Supabase — service role key is server-side only, never expose to browser
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
# Anon key is safe for browser — returned by GET /auth/config
SUPABASE_ANON_KEY=your-anon-key

# Dropbox App — from https://www.dropbox.com/developers/apps
DROPBOX_APP_KEY=your-dropbox-app-key
DROPBOX_APP_SECRET=your-dropbox-app-secret
# Must exactly match what you set in the Dropbox App Console
DROPBOX_REDIRECT_URI=http://localhost:3000/auth/dropbox/callback
# Root path to watch inside client Dropbox (leave empty for root)
DROPBOX_BASE_PATH=

# Inngest — from https://app.inngest.com
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# Slack — Bot token from your Slack app
SLACK_BOT_TOKEN=xoxb-your-bot-token
# Fallback channel ID when a client has no slack_channel_id configured
SLACK_DEFAULT_CHANNEL=C0123456789
